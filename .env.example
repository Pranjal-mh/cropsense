# Copy this file to .env and fill in your values.

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# CORS
CORS_ALLOW_ALL_ORIGINS=True

# --- Hugging Face model ---
# "api"   = call the free Hugging Face Inference API over HTTP (recommended)
# "local" = download and run the model locally with transformers/torch
HF_INFERENCE_MODE=api

# Any image-classification model fine-tuned on plant diseases works.
HF_MODEL_ID=linkanjarad/mobilenet_v2_1.0_224-plant-disease-identification

# Free token from https://huggingface.co/settings/tokens
# (Works without one on the free tier too, but you'll hit rate limits sooner.)
HF_API_TOKEN=

# Max upload size in bytes (default 8MB)
MAX_UPLOAD_SIZE=8388608
